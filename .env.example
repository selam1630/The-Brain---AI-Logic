# Backend Configuration
NEST_ENV=development
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/the-brain-db

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Speech-to-Text Configuration
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_key_here

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h

# GDPR & Privacy
GDPR_ENABLED=true
PRIVACY_EMAIL=privacy@thebrain.com

# i18n
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,pt,zh,ja,amharic

# Logging
LOG_LEVEL=debug
